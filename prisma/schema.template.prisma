// This file is rendered by commands/prepare-prisma.mjs.
// Set DATABASE_PROVIDER=postgresql or DATABASE_PROVIDER=sqlite before running Prisma commands.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "__DATABASE_PROVIDER__"
}

model Note {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  summary     String    @default("")
  tags        Json      @default("[]")
  resource    Json?
  attributes  Json?
  bookmarked  Boolean   @default(false)
  pinned      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  folder   Folder? @relation(fields: [folderId], references: [id])
  folderId Int?

  @@index([folderId])
}

enum NotesOrder {
  CREATED_AT_ASC
  CREATED_AT_DESC
  UPDATED_AT_ASC
  UPDATED_AT_DESC
  TITLE_ASC
  TITLE_DESC
}

enum NoteListViewMode {
  SUMMARY
  TITLE_ONLY
}

model Folder {
  id               Int              @id @default(autoincrement())
  name             String
  notes            Note[]
  order            NotesOrder       @default(UPDATED_AT_DESC)
  noteListViewMode NoteListViewMode @default(SUMMARY)
  isLocked         Boolean          @default(false)

  childFolders   Folder[] @relation("ParentFolder")
  parentFolder   Folder?  @relation("ParentFolder", fields: [parentFolderId], references: [id])
  parentFolderId Int?
}

model KeyValue {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
